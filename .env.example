# Copy to .env and fill in real values. Do NOT commit .env.

# Supabase (used for the optional auth/login flow)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Mailerlite (used by functions/subscribe-email.js — Netlify function)
# Only needed if you deploy the email-subscribe function.
MAILERLITE_API_KEY=your-mailerlite-api-key-here

# Geocoding endpoints (optional — defaults to public Photon).
# Override these if you self-host a Photon-compatible geocoder
# or proxy via your own infrastructure. Both endpoints must
# implement the Photon API response format.
# EXPO_PUBLIC_GEO_API_PRIMARY=https://your-geocoder.example.com/api/
# EXPO_PUBLIC_GEO_API_FALLBACK=https://photon.komoot.io/api/
